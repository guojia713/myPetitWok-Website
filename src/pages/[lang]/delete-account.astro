---
import Layout from '../../layouts/Layout.astro';
import { languages, langLabels, type Lang } from '../../i18n/content';
import { getDeleteAccount } from '../../i18n/delete-account';

export function getStaticPaths() {
  return languages.map((l) => ({ params: { lang: l } }));
}

const lang = Astro.params.lang as Lang;
const d = getDeleteAccount(lang);
---

<Layout title={`${d.title} — MyPetitWok`} description={d.intro} lang={lang}>
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-[var(--color-cream)]/95 backdrop-blur-sm border-b border-[var(--color-brand)]/15">
    <div class="max-w-6xl mx-auto px-6 h-18 flex items-center justify-between">
      <a href={`/${lang}`} class="flex items-center gap-2">
        <img src="/icon.png" alt="MyPetitWok" class="w-11 h-11 rounded-xl shadow-sm" />
        <span class="text-xl font-bold text-[var(--color-brand)]">MyPetitWok</span>
      </a>
      <div class="flex items-center gap-6 text-base">
        <div class="flex gap-1">
          {languages.map((l) => (
            <a
              href={`/${l}/delete-account`}
              class={`px-3 py-1.5 rounded-full text-sm font-bold transition-colors ${
                l === lang
                  ? 'bg-[var(--color-logo-red)] text-white'
                  : 'text-[var(--color-text-muted)] hover:bg-[var(--color-brand)]/10'
              }`}
            >
              {langLabels[l]}
            </a>
          ))}
        </div>
      </div>
    </div>
  </nav>

  <main class="pt-28 pb-16 px-6 bg-[var(--color-cream)] min-h-screen">
    <article class="max-w-3xl mx-auto bg-white rounded-2xl shadow-sm border border-[var(--color-brand)]/15 p-8 sm:p-12">
      <h1 class="text-4xl font-extrabold text-[var(--color-brand-dark)] mb-2">{d.title}</h1>
      <p class="text-sm text-[var(--color-text-muted)] mb-6">{d.lastUpdated}</p>
      <p class="text-lg text-[var(--color-text)] leading-relaxed mb-10">{d.intro}</p>

      <div class="flex flex-col gap-8">
        <!-- In-app deletion -->
        <section>
          <h2 class="text-xl font-bold text-[var(--color-logo-red)] mb-3">{d.inAppTitle}</h2>
          <ol class="list-decimal list-inside text-[var(--color-text)] leading-relaxed flex flex-col gap-2">
            {d.inAppSteps.map((step) => (
              <li>{step}</li>
            ))}
          </ol>
        </section>

        <!-- Email deletion -->
        <section>
          <h2 class="text-xl font-bold text-[var(--color-logo-red)] mb-3">{d.emailTitle}</h2>
          <p class="text-[var(--color-text)] leading-relaxed">{d.emailBody}</p>
        </section>

        <!-- Data note -->
        <section class="bg-[var(--color-cream)] rounded-xl p-6 border border-[var(--color-brand)]/10">
          <p class="text-[var(--color-text-muted)] leading-relaxed">{d.dataNote}</p>
        </section>
      </div>

      <div class="mt-12 pt-8 border-t border-[var(--color-brand)]/15">
        <a href={`/${lang}`} class="text-[var(--color-logo-red)] font-bold hover:underline">{d.back}</a>
      </div>
    </article>
  </main>

  <footer class="py-8 px-6 border-t border-[var(--color-brand)]/15 bg-[var(--color-cream)]">
    <div class="max-w-4xl mx-auto text-center text-sm text-[var(--color-text-muted)]">
      <span>&copy; {new Date().getFullYear()} MyPetitWok</span>
    </div>
  </footer>
</Layout>
