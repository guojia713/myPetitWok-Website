---
import Layout from '../layouts/Layout.astro';
import { t, languages, langLabels, type Lang } from '../i18n/content';

export function getStaticPaths() {
  return languages.map((l) => ({ params: { lang: l } }));
}

const lang = Astro.params.lang as Lang;
const i = t(lang);

const featureIcons = [
  // Wok / recipes
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-2.21 0-4 .9-4 2v1c0 3.31 1.79 6 4 6s4-2.69 4-6v-1c0-1.1-1.79-2-4-2z"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 10c-2.5.5-4 1.5-4 2.5C4 14 7.58 15 12 15s8-1 8-2.5c0-1-.5-2-4-2.5"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v2m-3-1l1 1.5M15 5l-1 1.5"/></svg>`,
  // Filter / categories
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg>`,
  // Heart / favourites
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`,
];
---

<Layout title="MyPetitWok — Asian recipes made simple" description={i.hero.tagline} lang={lang}>
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-[var(--color-cream)]/95 backdrop-blur-sm border-b border-[var(--color-brand)]/15">
    <div class="max-w-6xl mx-auto px-6 h-18 flex items-center justify-between">
      <a href={`/${lang}`} class="flex items-center gap-2">
        <img src="/icon.png" alt="MyPetitWok" class="w-11 h-11 rounded-xl shadow-sm" />
        <span class="text-xl font-bold text-[var(--color-brand)]">MyPetitWok</span>
      </a>
      <div class="flex items-center gap-6 text-base">
        <a href="#features" class="hidden sm:block font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-logo-red)] transition-colors">{i.nav.features}</a>
        <a href="#download" class="hidden sm:block font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-logo-red)] transition-colors">{i.nav.download}</a>
        <div class="flex gap-1">
          {languages.map((l) => (
            <a
              href={`/${l}`}
              class={`px-3 py-1.5 rounded-full text-sm font-bold transition-colors ${
                l === lang
                  ? 'bg-[var(--color-logo-red)] text-white'
                  : 'text-[var(--color-text-muted)] hover:bg-[var(--color-brand)]/10'
              }`}
            >
              {langLabels[l]}
            </a>
          ))}
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-34 pb-20 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-10 md:gap-16">
      <!-- Left: title + tagline + store badges -->
      <div class="flex-1 text-center md:text-left">
        <div class="flex items-center gap-3 justify-center md:justify-start mb-6">
          <img src="/icon.png" alt="MyPetitWok" class="w-18 h-18 rounded-2xl shadow-md" />
          <h1 class="text-3xl sm:text-4xl font-extrabold hero-title leading-tight">
            My Petit Wok ( Cooking now)
          </h1>
        </div>
        <p class="text-xl sm:text-2xl text-[var(--color-text)] leading-relaxed max-w-2xl mx-auto md:mx-0 font-medium">
          {i.hero.tagline}
        </p>
        <!-- Store badges -->
        <div id="download" class="mt-8 flex flex-wrap gap-3 justify-center md:justify-start scroll-mt-28">
          <div class="bg-[var(--color-brand-dark)] text-white px-5 py-3 rounded-xl flex items-center gap-2 opacity-75">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <div class="text-left">
              <div class="text-xs leading-tight opacity-85">{i.hero.comingSoon}</div>
              <div class="text-base font-semibold leading-tight">App Store</div>
            </div>
          </div>
          <div class="bg-[var(--color-brand-dark)] text-white px-5 py-3 rounded-xl flex items-center gap-2 opacity-75">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M3 20.5v-17c0-.59.34-1.11.84-1.35L13.69 12l-9.85 9.85c-.5-.24-.84-.76-.84-1.35m13.81-5.38L6.05 21.34l8.49-8.49 2.27 2.27m.91-.91L19.59 12l-1.86-2.21L14.27 13.25l3.45 3.96M6.05 2.66l10.76 6.22-2.27 2.27-8.49-8.49z"/></svg>
            <div class="text-left">
              <div class="text-xs leading-tight opacity-85">{i.hero.comingSoon}</div>
              <div class="text-base font-semibold leading-tight">Google Play</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features with app screenshots -->
  <section id="features" class="py-20 px-6 bg-[var(--color-bg)]">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-4xl font-extrabold text-center mb-16 text-[var(--color-brand-dark)]">{i.features.title}</h2>
      <div class="flex flex-col gap-24">
        {i.features.items.map((item, idx) => (
          <div class={`flex flex-col ${idx % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} items-center gap-10`}>
            <!-- App screenshot(s) -->
            <div class="flex-shrink-0 flex flex-col sm:flex-row gap-4 items-center">
              {idx === 0 ? (
                <>
                  <button class="photo-trigger" type="button" data-fullscreen-photo="/screenshots/feature-1.jpg" aria-label="Open screenshot 1 full screen">
                    <img src="/screenshots/feature-1.jpg" alt="" class="w-[180px] h-[360px] sm:w-[220px] sm:h-[440px] object-cover rounded-2xl shadow-xl border-4 border-white" />
                  </button>
                  <button class="photo-trigger" type="button" data-fullscreen-photo="/screenshots/feature-1.1.png" aria-label="Open screenshot 1.1 full screen">
                    <img src="/screenshots/feature-1.1.png" alt="" class="w-[180px] h-[360px] sm:w-[220px] sm:h-[440px] object-cover rounded-2xl shadow-xl border-4 border-white" />
                  </button>
                </>
              ) : idx === 1 ? (
                <>
                  <button class="photo-trigger" type="button" data-fullscreen-photo="/screenshots/feature-2.jpg" aria-label="Open screenshot 2 full screen">
                    <img src="/screenshots/feature-2.jpg" alt="" class="w-[180px] h-[360px] sm:w-[220px] sm:h-[440px] object-cover rounded-2xl shadow-xl border-4 border-white" />
                  </button>
                  <button class="photo-trigger" type="button" data-fullscreen-photo="/screenshots/feature-2.1.jpg" aria-label="Open screenshot 2.1 full screen">
                    <img src="/screenshots/feature-2.1.jpg" alt="" class="w-[180px] h-[360px] sm:w-[220px] sm:h-[440px] object-cover rounded-2xl shadow-xl border-4 border-white" />
                  </button>
                </>
              ) : (
                <button class="photo-trigger" type="button" data-fullscreen-photo={`/screenshots/feature-${idx + 1}.jpg`} aria-label={`Open screenshot ${idx + 1} full screen`}>
                  <img src={`/screenshots/feature-${idx + 1}.jpg`} alt="" class="w-[300px] h-[600px] object-cover rounded-2xl shadow-xl border-4 border-white" />
                </button>
              )}
            </div>
            <!-- Feature text -->
            <div class="flex-1 text-center md:text-left">
              <div class="text-[var(--color-logo-red)] mb-4" set:html={featureIcons[idx]} />
              <p class="text-xl sm:text-2xl text-[var(--color-text)] leading-relaxed font-medium">{item}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- More features -->
  <section class="py-20 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-4xl font-extrabold text-center mb-12 text-[var(--color-brand-dark)]">{i.more.title}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {i.more.items.map((item) => (
          <div class="bg-white rounded-xl p-6 hover:shadow-md transition-shadow border border-[var(--color-brand)]/15">
            <h3 class="font-bold text-[var(--color-logo-red)] mb-2 text-xl">{item.label}</h3>
            <p class="text-[var(--color-text-muted)] text-lg leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-10">
      <!-- Family photo -->
      <div class="flex-shrink-0">
        <button class="photo-trigger" type="button" data-fullscreen-photo="/family.png" aria-label="Open family photo full screen">
          <img src="/family.png" alt="Family" class="w-[400px] h-[300px] object-cover rounded-2xl shadow-md border-4 border-[var(--color-cream)]" />
        </button>
      </div>
      <!-- Text -->
      <div class="flex-1">
        <h2 class="text-4xl font-extrabold text-center md:text-left mb-8 text-[var(--color-brand-dark)]">{i.story.title}</h2>
        <div class="text-[var(--color-text-muted)] leading-relaxed text-xl whitespace-pre-line">
          {i.story.text}
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-[var(--color-brand)]/15 bg-[var(--color-cream)]">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-[var(--color-text-muted)] mb-2 text-lg">{i.footer.contact}</p>
      <a href={`mailto:${i.footer.email}`} class="text-[var(--color-logo-red)] text-lg font-bold hover:underline">{i.footer.email}</a>
      <div class="mt-6">
        <a href={`/${lang}/privacy`} class="text-[var(--color-text-muted)] text-sm hover:text-[var(--color-logo-red)] hover:underline">
          {lang === 'fr' ? 'Politique de confidentialité' : lang === 'zh' ? '隐私政策' : 'Privacy Policy'}
        </a>
      </div>
      <div class="mt-8 flex items-center justify-center gap-2 text-base text-[var(--color-text-muted)]">
        <img src="/icon.png" alt="" class="w-7 h-7 rounded" />
        <span>&copy; {new Date().getFullYear()} MyPetitWok. {i.footer.rights}</span>
      </div>
    </div>
  </footer>

  <dialog class="photo-lightbox" aria-label="Full screen photo viewer">
    <button class="photo-lightbox__close" type="button" aria-label="Close full screen photo">&times;</button>
    <img src="" alt="" data-lightbox-image />
  </dialog>

  <script>
    const dialog = document.querySelector<HTMLDialogElement>('.photo-lightbox');
    const lightboxImage = document.querySelector<HTMLImageElement>('[data-lightbox-image]');
    const closeButton = document.querySelector<HTMLButtonElement>('.photo-lightbox__close');

    document.querySelectorAll<HTMLButtonElement>('[data-fullscreen-photo]').forEach((button) => {
      button.addEventListener('click', () => {
        if (!dialog || !lightboxImage) return;

        const photo = button.dataset.fullscreenPhoto;
        const preview = button.querySelector('img');
        if (!photo) return;

        lightboxImage.src = photo;
        lightboxImage.alt = preview?.alt || '';
        dialog.showModal();
      });
    });

    closeButton?.addEventListener('click', () => dialog?.close());
    dialog?.addEventListener('click', (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });
  </script>
</Layout>
