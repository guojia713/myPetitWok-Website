---
import '@fontsource-variable/inter/index.css';
import '../styles/global.css';
import { t, launchDate, type Lang } from '../i18n/content';

interface Props {
  title: string;
  description: string;
  lang?: string;
  /** Per-language paths for hreflang. If omitted, falls back to /{lang} for all. */
  alternates?: Partial<Record<'en' | 'fr' | 'zh', string>>;
  /** Absolute URL for og:image. Defaults to the app icon. */
  ogImage?: string;
}

const { title, description, lang = 'en', alternates, ogImage } = Astro.props;
const resolvedOgImage = ogImage ?? 'https://mypetitwok.com/icon.png';
const i = t(lang as Lang);

const siteUrl = 'https://mypetitwok.com';
const langs = ['en', 'fr', 'zh'] as const;

const resolvedAlternates: Record<'en' | 'fr' | 'zh', string> = {
  en: alternates?.en ?? '/en',
  fr: alternates?.fr ?? '/fr',
  zh: alternates?.zh ?? '/zh',
};

const canonicalUrl = `${siteUrl}${resolvedAlternates[lang as 'en' | 'fr' | 'zh']}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />

    <!-- hreflang for multilingual SEO -->
    {langs.map((l) => (
      <link rel="alternate" hreflang={l} href={`${siteUrl}${resolvedAlternates[l]}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${resolvedAlternates.en}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta property="og:locale" content={lang} />
    <title>{title}</title>

    <!-- Structured data: MobileApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MobileApplication",
      "name": "MyPetitWok",
      "url": `https://mypetitwok.com/${lang}`,
      "description": description,
      "image": "https://mypetitwok.com/icon.png",
      "applicationCategory": "FoodApplication",
      "operatingSystem": "iOS, Android",
      "inLanguage": ["en", "fr", "zh"],
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR"
      },
      "author": {
        "@type": "Person",
        "email": "hello@mypetitwok.com"
      }
    })} />

    <!-- Structured data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "MyPetitWok",
      "alternateName": "小锅",
      "url": siteUrl,
      "logo": `${siteUrl}/icon.png`,
      "email": "hello@mypetitwok.com",
      "description": "Maker of MyPetitWok, a free mobile app for authentic Asian recipes, ingredient guides and shopping help."
    })} />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MP5NT96945"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MP5NT96945');
    </script>
  </head>
  <body class="antialiased">
    <!-- Launch countdown banner -->
    <div class="launch-banner text-white">
      <div class="max-w-6xl mx-auto px-6 py-2.5 flex flex-wrap items-center justify-center gap-x-5 gap-y-1.5 text-center">
        <span class="font-semibold text-sm sm:text-base">{i.launch.prefix}</span>
        <div id="countdown" class="countdown" data-launch={launchDate}>
          <span class="cd-unit"><b data-cd="days">--</b><i>{i.countdown.days}</i></span>
          <span class="cd-sep">:</span>
          <span class="cd-unit"><b data-cd="hours">--</b><i>{i.countdown.hours}</i></span>
          <span class="cd-sep">:</span>
          <span class="cd-unit"><b data-cd="minutes">--</b><i>{i.countdown.minutes}</i></span>
          <span class="cd-sep">:</span>
          <span class="cd-unit"><b data-cd="seconds">--</b><i>{i.countdown.seconds}</i></span>
        </div>
        <span id="countdown-live" class="font-semibold text-sm sm:text-base hidden" data-live-text={i.launch.live}></span>
      </div>
    </div>

    <slot />

    <!-- Launch countdown script -->
    <script>
      const root = document.getElementById('countdown');
      const liveEl = document.getElementById('countdown-live');

      if (root) {
        const target = new Date(root.dataset.launch ?? '').getTime();
        const fields: Record<string, HTMLElement | null> = {
          days: root.querySelector('[data-cd="days"]'),
          hours: root.querySelector('[data-cd="hours"]'),
          minutes: root.querySelector('[data-cd="minutes"]'),
          seconds: root.querySelector('[data-cd="seconds"]'),
        };

        const pad = (n: number) => String(n).padStart(2, '0');

        const tick = () => {
          const diff = target - Date.now();
          if (diff <= 0) {
            root.classList.add('hidden');
            if (liveEl) {
              liveEl.textContent = liveEl.dataset.liveText ?? '';
              liveEl.classList.remove('hidden');
            }
            return false;
          }
          const totalSeconds = Math.floor(diff / 1000);
          const days = Math.floor(totalSeconds / 86400);
          const hours = Math.floor((totalSeconds % 86400) / 3600);
          const minutes = Math.floor((totalSeconds % 3600) / 60);
          const seconds = totalSeconds % 60;
          if (fields.days) fields.days.textContent = String(days);
          if (fields.hours) fields.hours.textContent = pad(hours);
          if (fields.minutes) fields.minutes.textContent = pad(minutes);
          if (fields.seconds) fields.seconds.textContent = pad(seconds);
          return true;
        };

        if (tick()) {
          const timer = setInterval(() => {
            if (!tick()) clearInterval(timer);
          }, 1000);
        }
      }
    </script>
  </body>
</html>
