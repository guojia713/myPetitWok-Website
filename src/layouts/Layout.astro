---
import '@fontsource-variable/inter/index.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
  /** Per-language paths for hreflang. If omitted, falls back to /{lang} for all. */
  alternates?: Partial<Record<'en' | 'fr' | 'zh', string>>;
  /** Absolute URL for og:image. Defaults to the app icon. */
  ogImage?: string;
}

const { title, description, lang = 'en', alternates, ogImage } = Astro.props;
const resolvedOgImage = ogImage ?? 'https://mypetitwok.com/icon.png';

const siteUrl = 'https://mypetitwok.com';
const langs = ['en', 'fr', 'zh'] as const;

// The static build and sitemap serve every route with a trailing slash
// (e.g. /en/, /en/recipes/). Canonical, hreflang and structured-data URLs
// must match that exact form, or Google flags the slashed URL it crawls as a
// "duplicate page with proper canonical tag" against the slash-less canonical.
const withSlash = (path: string) => (path.endsWith('/') ? path : `${path}/`);

const resolvedAlternates: Record<'en' | 'fr' | 'zh', string> = {
  en: withSlash(alternates?.en ?? '/en'),
  fr: withSlash(alternates?.fr ?? '/fr'),
  zh: withSlash(alternates?.zh ?? '/zh'),
};

const canonicalUrl = `${siteUrl}${resolvedAlternates[lang as 'en' | 'fr' | 'zh']}`;

// OG locale wants the full ll_CC form, not just the language code.
const ogLocaleMap: Record<'en' | 'fr' | 'zh', string> = {
  en: 'en_US',
  fr: 'fr_FR',
  zh: 'zh_CN',
};
const ogLocale = ogLocaleMap[lang as 'en' | 'fr' | 'zh'] ?? 'en_US';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />

    <!-- App Store smart banner — shows a native "Get" prompt in mobile Safari. -->
    <meta name="apple-itunes-app" content="app-id=6768055249" />

    <!-- hreflang for multilingual SEO -->
    {langs.map((l) => (
      <link rel="alternate" hreflang={l} href={`${siteUrl}${resolvedAlternates[l]}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${resolvedAlternates.en}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="My Petit Wok" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta property="og:locale" content={ogLocale} />
    <title>{title}</title>

    <!-- Structured data: MobileApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MobileApplication",
      "name": "MyPetitWok",
      "url": canonicalUrl,
      "description": description,
      "image": "https://mypetitwok.com/icon.png",
      "applicationCategory": "FoodApplication",
      "operatingSystem": "iOS, Android",
      "installUrl": "https://apps.apple.com/app/id6768055249",
      "downloadUrl": "https://apps.apple.com/app/id6768055249",
      "inLanguage": ["en", "fr", "zh"],
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR"
      },
      "author": {
        "@type": "Person",
        "email": "hello@mypetitwok.com"
      }
    })} />

    <!-- Structured data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "MyPetitWok",
      "alternateName": "小锅",
      "url": siteUrl,
      "logo": `${siteUrl}/icon.png`,
      "email": "hello@mypetitwok.com",
      "description": "Maker of MyPetitWok, a free mobile app for authentic Asian recipes, ingredient guides and shopping help."
    })} />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MP5NT96945"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MP5NT96945');
    </script>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
